# ========== 大模型配置 ==========
# 阿里云百炼 DashScope API Key
DASHSCOPE_API_KEY=your-api-key-here
# 模型名（对应 Java 项目的 qwen-plus）
DASHSCOPE_MODEL=qwen-plus
# OpenAI 兼容模式端点（默认即为百炼兼容端点，一般无需修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM 生成参数（可选）
LLM_TEMPERATURE=0.7
LLM_ENABLE_THINKING=false
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ========== 服务配置 ==========
# 服务端口（对应 Java 的 8123）
APP_PORT=8123
# 是否开启 DEBUG 日志
DEBUG=false
# API 鉴权：逗号分隔的 Key 列表；留空=关闭鉴权（本地开发默认，生产务必配置）
API_KEYS=
# 限流：单 IP 每分钟最大请求数（0=不限流）
RATE_LIMIT_PER_MINUTE=60
# 单条用户消息最大长度（字符）
MAX_MESSAGE_LENGTH=4000
# CORS 允许的前端源（逗号分隔，支持通配符 *）
# 本地开发默认放行 Vite dev server；生产环境请改为实际域名
# 例：https://your-domain.com 或 * （不建议生产用 *）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:8080

# ========== Agent 配置 ==========
# 单次任务最大步数（对应 Java BaseAgent.maxSteps）
AGENT_MAX_STEPS=5

# ========== 搜索 API（可选，对应 Java 的 search-api） ==========
# Serper.dev Google Search API Key，用于 search_web 工具
SEARCH_API_KEY=

# ========== 对话记忆持久化 ==========
# 记忆文件目录（对应 Java 的 FileBasedChatMemory）
MEMORY_DIR=./data/memory
# file | postgres
MEMORY_STORE_TYPE=file
MEMORY_TABLE_NAME=message_store

# ========== MCP 服务（可选） ==========
# 高德地图 MCP
AMAP_MAPS_API_KEY=
# 图片素材 API，占位备用
PEXELS_API_KEY=

# ========== RAG 知识库 ==========
EMBEDDING_MODEL=text-embedding-v2
# chroma | postgres | milvus
VECTOR_STORE_TYPE=chroma
VECTOR_DB_DIR=./data/vector_db
RAG_K=3
MILVUS_URI=

# PostgreSQL / pgvector（VECTOR_STORE_TYPE=postgres 或 MEMORY_STORE_TYPE=postgres 时使用）
POSTGRES_CONNECTION_STRING=postgresql://postgres:postgres@localhost:5433/xianzhi
POSTGRES_COLLECTION=xianzhi_knowledge
# DashScope embedding 不可用时回退本地 HuggingFace 模型（true/false）
EMBEDDING_LOCAL_FALLBACK=true
# 检索结果缓存 TTL（秒），0=不缓存，避免多轮对话重复调用 embedding
RAG_SEARCH_CACHE_TTL=60

# ========== LangSmith 可观测性（可选） ==========
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=xianzhi-agent
LANGSMITH_TRACING=false

# ========== 微信小程序登录（可选，uniapp 微信小程序端使用） ==========
# 在微信公众平台 → 开发管理 → 开发设置 获取
WECHAT_APPID=
WECHAT_SECRET=
